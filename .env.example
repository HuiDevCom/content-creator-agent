# AI Gateway Configuration
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=your-gateway-url

# Model (optional, defaults to @makers/deepseek-v4-flash)
# AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# Web Search Provider
# Options: wsa (Tencent Cloud WSA, default), kimi (Kimi $web_search)
# SEARCH_PROVIDER=wsa

# Kimi API Key (required when SEARCH_PROVIDER=kimi)
# KIMI_API_KEY=your-kimi-api-key

# Web Search API Key (Tencent Cloud WSA)
# Required for the built-in web_search tool when SEARCH_PROVIDER=wsa (default).
# Without this, search falls back to no-op (no real results). Obtain from https://console.cloud.tencent.com/
WSA_API_KEY=your-wsa-api-key

# Site public URL (optional)
# Set this to your custom domain to generate share links with the correct domain.
# If not set, the current browser origin (window.location.origin) will be used.
NEXT_PUBLIC_SITE_URL=https://content-creator.agent.huidev.com

# GitHub OAuth (optional, for user-specific article isolation)
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set the callback URL to your app's URL (e.g., http://localhost:3000)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret